{
  "workflowApiVersion": "1.1",
  "type": "REST",
  "metaData": {
    "icon": "https://cdn-icons-png.flaticon.com/512/733/733585.png",
    "category": "message"
  },
  "lang": {
    "pt-BR": {
      "name": "Enviar WhatsApp",
      "description": "Disparo com mensagem customizada"
    }
  },
  "arguments": {
    "execute": {
      "url": "https://seu-backend.com/execute",
      "verb": "POST",
      "body": {
        "phone": "{{Contact.Default.Phone}}",
        "nome": "{{Contact.Default.FirstName}}",
        "mensagem": "{{Activity.mensagem}}"
      }
    }
  },
  "configurationArguments": {
    "save": {
      "url": "https://webhook.site/seu-id",
      "verb": "POST"
    },
    "publish": {
      "url": "https://webhook.site/seu-id",
      "verb": "POST"
    },
    "validate": {
      "url": "https://webhook.site/seu-id",
      "verb": "POST"
    }
  },
  "userInterfaces": {
    "configModal": {
      "url": "https://drikahz.github.io/teste/",
      "height": 600,
      "width": 800
    }
  }
}
